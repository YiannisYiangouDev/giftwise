{
  "manifest_version": 3,
  "name": "GiftWise Quick Clip",
  "version": "1.0.0",
  "description": "Clip product items from any store directly into your GiftWise wishlists.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
