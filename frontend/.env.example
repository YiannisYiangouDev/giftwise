# --- PUBLIC (safe for browser, prefixed with NEXT_PUBLIC_) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- SERVER-ONLY (NEVER expose to browser, no NEXT_PUBLIC_ prefix) ---
# Used by API routes, admin dashboard, account deletion
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin bootstrap (emails that can access /admin before admins table is seeded)
ADMIN_EMAILS=your-email@example.com

# FlareSolverr — Cloudflare bypass for product fetch (optional)
FLARESOLVERR_URL=http://localhost:8191
